{
    "dataset_id": "memoria-graph-entity-v2",
    "version": "v1.0",
    "description": "Extended graph benchmark. Tests 4-hop chains, entity alias resolution, negative relationships, multi-entity convergence, entity state evolution, and cross-session entity linking. All scenarios require graph traversal to pass — vector-only retrieval will fail.",
    "scenarios": [
        {
            "scenario_id": "GRAPH2-001",
            "title": "Four-hop chain: person → team → project → dependency → vulnerability",
            "description": "Query names only the person. Answer requires 4 hops: Bob → backend team → payment-service → stripe-sdk → CVE. Vector cannot bridge 'Bob' to 'CVE' with no semantic overlap.",
            "domain": "engineering",
            "difficulty": "L5",
            "horizon": "long",
            "tags": [
                "trust"
            ],
            "seed_memories": [
                {
                    "content": "Bob 是后端团队的成员，负责 payment-service 的日常维护。",
                    "memory_type": "semantic"
                },
                {
                    "content": "payment-service 使用 stripe-sdk v3.2.1 处理支付请求。",
                    "memory_type": "semantic"
                },
                {
                    "content": "stripe-sdk v3.2.1 存在 CVE-2024-11223 漏洞，可能导致支付数据泄露。",
                    "memory_type": "semantic"
                },
                {
                    "content": "Alice 负责 auth-service，与 payment-service 无关。",
                    "memory_type": "semantic",
                    "is_noise": true
                },
                {
                    "content": "前端团队使用 React 18，不涉及支付逻辑。",
                    "memory_type": "semantic",
                    "is_noise": true
                }
            ],
            "steps": [],
            "assertions": [
                {
                    "query": "Bob 负责的东西有没有安全漏洞？",
                    "top_k": 3,
                    "expected_contents": [
                        "CVE-2024-11223",
                        "支付数据泄露",
                        "stripe-sdk"
                    ],
                    "excluded_contents": [
                        "auth-service",
                        "React 18"
                    ]
                }
            ],
            "maturation": [
                "extract_entities",
                "consolidate"
            ]
        },
        {
