{
    "dataset_id": "memoria-graph-entity-v1",
    "version": "v1.0",
    "description": "Graph + Entity architecture benchmark. Tests multi-hop reasoning, entity disambiguation, and contextual retrieval where graph structure provides a measurable advantage over pure vector/fulltext. Each scenario is designed so that vector-only retrieval will fail on at least one assertion.",
    "scenarios": [
        {
            "scenario_id": "GRAPH-001",
            "title": "Two-hop entity bridge: person → module → vulnerability",
            "description": "Query names only the person (Alice). Answer requires two hops: Alice → auth-service → CVE. Vector fails because 'Alice' and 'CVE-2024-33531' share zero semantic overlap; only the entity graph connects them.",
            "domain": "engineering",
            "difficulty": "L4",
            "horizon": "medium",
            "tags": [
                "trust"
            ],
            "seed_memories": [
                {
                    "content": "Alice 负责 auth-service 模块的开发和维护。",
                    "memory_type": "semantic"
                },
                {
                    "content": "auth-service 使用了 jsonwebtoken 库 v8.5.1 来处理用户认证。",
                    "memory_type": "semantic"
                },
                {
                    "content": "jsonwebtoken v8.5.1 存在 CVE-2024-33531 漏洞，可能导致 token 伪造。",
                    "memory_type": "semantic"
                },
                {
                    "content": "Bob 负责 payment-service 模块，使用 Stripe SDK。",
                    "memory_type": "semantic",
                    "is_noise": true
                },
                {
                    "content": "公司安全策略要求所有依赖每季度审计一次。",
                    "memory_type": "semantic",
                    "is_noise": true
                }
            ],
            "steps": [],
            "assertions": [
                {
                    "query": "Alice 负责的东西有没有已知问题？",
                    "top_k": 3,
                    "expected_contents": [
                        "CVE-2024-33531",
                        "token 伪造",
                        "jsonwebtoken"
                    ],
                    "excluded_contents": [
                        "payment-service",
                        "Stripe",
                        "季度审计"
                    ],
                    "follow_ups": [
                        {
                            "name": "entity_expand",
                            "description": "Agent sees auth-service in results, queries it next",
                            "max_rounds": 2,
                            "mode": "entity_expand"
                        },
                        {
                            "name": "explicit_chain",
                            "description": "Agent explicitly follows the person->module->vuln chain",
                            "max_rounds": 2,
                            "mode": "entity_expand",
                            "follow_up_queries": [
                                "auth-service 依赖库",
                                "jsonwebtoken 漏洞"
                            ]
                        }
                    ]
                }
            ],
            "maturation": [
                "extract_entities",
                "consolidate"
            ]
        },
        {
