# Memoria — MatrixOne Configuration
# Copy to .env and modify as needed:  cp .env.example .env
# All settings are optional — defaults work out of the box.

# ── MatrixOne Image ──────────────────────────────────────────────────
# Pin to a specific version for reproducibility, or use 'latest'
MO_IMAGE=matrixorigin/matrixone:latest

# ── Network ──────────────────────────────────────────────────────────
# Port exposed on host (MatrixOne listens on 6001 inside container)
MO_PORT=6001

# ── Storage ──────────────────────────────────────────────────────────
# Data directory on host — all database files persist here
# Use absolute path for production, relative path for development
MO_DATA_DIR=./data/matrixone

# ── Resources ────────────────────────────────────────────────────────
# Memory limit for the container
# Minimum: 1g (basic usage), Recommended: 2g, Production: 4g+
MO_MEMORY_LIMIT=2g

# ── Logging ──────────────────────────────────────────────────────────
# Max size per log file before rotation
MO_LOG_MAX_SIZE=10m
# Number of rotated log files to keep
MO_LOG_MAX_FILES=3

# ── Container ────────────────────────────────────────────────────────
MO_CONTAINER_NAME=memoria-matrixone

# ── Timezone ─────────────────────────────────────────────────────────
TZ=UTC
